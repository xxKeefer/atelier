{
  "$schema": "https://tr.designtokens.org/format/",
  "duration": {
    "$type": "duration",
    "$description": "Motion durations. Tactile feedback is quick; overlays slower.",
    "instant": { "$value": "0ms" },
    "fast": { "$value": "100ms", "$description": "hover/press feedback" },
    "base": { "$value": "150ms", "$description": "default transition" },
    "slow": { "$value": "300ms", "$description": "overlays, larger moves" },
    "slower": { "$value": "500ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "$description": "Easing curves, map to Tailwind --ease-*.",
    "linear": { "$value": [0, 0, 1, 1] },
    "in": { "$value": [0.4, 0, 1, 1] },
    "out": { "$value": [0, 0, 0.2, 1] },
    "in-out": { "$value": [0.4, 0, 0.2, 1] },
    "spring": {
      "$value": [0.34, 1.56, 0.64, 1],
      "$description": "slight overshoot - the tactile 'lift to greet the cursor' bounce"
    }
  }
}
