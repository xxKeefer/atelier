{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "$type": "color",
    "$description": "Tier-2 semantic roles, dark-first; all values reference the tier-1 palette.",
    "bg": {
      "canvas": {
        "$value": "{palette.neutral.950}",
        "$description": "page background - the floor everything sits on, below the surface ramp"
      },
      "scrim": {
        "$value": "rgba(10, 10, 15, 0.8)",
        "$description": "backdrop behind overlays that sit above the whole page: modals, sliding sheets."
      }
    },
    "surface": {
      "$description": "Element surface ramp: the three planes the elevation ladder draws from.",
      "subtle": {
        "$value": "{palette.neutral.900}",
        "$description": "recessed surfaces (lower / low): inputs, wells, selected checkbox/radio, switch track."
      },
      "default": {
        "$value": "{palette.neutral.800}",
        "$description": "resting plane (default): cards, panels, fields."
      },
      "strong": {
        "$value": "{palette.neutral.700}",
        "$description": "raised surfaces (high / higher) + overlays: popped buttons, menus, modals."
      }
    },
    "fg": {
      "default": {
        "$value": "{palette.neutral.50}",
        "$description": "primary text"
      },
      "muted": {
        "$value": "{palette.neutral.200}",
        "$description": "secondary text"
      },
      "subtle": {
        "$value": "{palette.neutral.300}",
        "$description": "tertiary / placeholder text"
      },
      "disabled": {
        "$value": "{palette.neutral.600}",
        "$description": "disabled text"
      },
      "inverse": {
        "$value": "{palette.neutral.950}",
        "$description": "text on light / solid fills"
      }
    },
    "border": {
      "default": {
        "$value": "{palette.neutral.700}"
      },
      "subtle": {
        "$value": "{palette.neutral.800}"
      },
      "strong": {
        "$value": "{palette.neutral.600}"
      },
      "focus": {
        "$value": "{palette.magenta.500}",
        "$description": "focus ring"
      }
    },
    "primary": {
      "default": {
        "$value": "{palette.magenta.500}",
        "$description": "primary brand fill"
      },
      "hover": {
        "$value": "{palette.magenta.400}"
      },
      "active": {
        "$value": "{palette.magenta.600}"
      },
      "subtle": {
        "$value": "{palette.magenta.900}",
        "$description": "tinted background"
      },
      "surface-subtle": {
        "$value": "{palette.magenta.900}",
        "$description": "recessed plane (lower/low rungs)"
      },
      "surface-strong": {
        "$value": "{palette.magenta.700}",
        "$description": "lifted plane (high/higher rungs)"
      },
      "surface-recess": {
        "$value": "{palette.magenta.600}",
        "$description": "shared plane for the lower/low/flat rungs"
