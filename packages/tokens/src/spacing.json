{
  "$schema": "https://tr.designtokens.org/format/",
  "spacing": {
    "$type": "dimension",
    "$description": "Spacing scale on a 4px (0.25rem) base; keys mirror Tailwind --spacing-*.",
    "0": { "$value": "0" },
    "px": { "$value": "1px", "$description": "hairline / border-width spacing" },
    "0.5": { "$value": "0.125rem", "$description": "2px" },
    "1": { "$value": "0.25rem", "$description": "4px" },
    "1.5": { "$value": "0.375rem", "$description": "6px" },
    "2": { "$value": "0.5rem", "$description": "8px" },
    "2.5": { "$value": "0.625rem", "$description": "10px" },
    "3": { "$value": "0.75rem", "$description": "12px" },
    "4": { "$value": "1rem", "$description": "16px - base rhythm" },
    "5": { "$value": "1.25rem", "$description": "20px" },
    "6": { "$value": "1.5rem", "$description": "24px" },
    "8": { "$value": "2rem", "$description": "32px" },
    "10": { "$value": "2.5rem", "$description": "40px" },
    "12": { "$value": "3rem", "$description": "48px" },
    "16": { "$value": "4rem", "$description": "64px - section gaps" },
    "20": { "$value": "5rem", "$description": "80px" },
    "24": { "$value": "6rem", "$description": "96px" },
    "32": { "$value": "8rem", "$description": "128px - large layout gaps" },
    "lift": {
      "$description": "Y-translation companion to the elevation ladder; each value equals its shadow's bottom-edge height so a press-to-flush keeps the top edge in place.",
      "half": { "$value": "2px", "$description": "high edge height: hover-press displacement" },
      "full": {
        "$value": "4px",
        "$description": "higher edge height: full press-to-flush displacement"
      }
    }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Corner radius, t-shirt sized, maps to Tailwind --radius-*.",
    "none": { "$value": "0", "$description": "sharp corners (neo-brutalist)" },
    "sm": { "$value": "0.25rem", "$description": "4px - inputs, small controls" },
    "md": { "$value": "0.5rem", "$description": "8px - cards, buttons (matches prior project)" },
    "lg": { "$value": "0.75rem", "$description": "12px" },
    "xl": { "$value": "1rem", "$description": "16px - large panels, modals" },
    "2xl": { "$value": "1.5rem", "$description": "24px" },
    "full": { "$value": "9999px", "$description": "pills, avatars, circular" }
  }
}
