{
  "name": "atelier",
  "version": "0.0.0",
  "private": true,
  "description": "A personal design system and Vue component library, built in public.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "test:update": "pnpm -r test:update",
    "storybook": "pnpm -r storybook",
    "build-storybook": "pnpm -r build-storybook",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0"
  }
}
